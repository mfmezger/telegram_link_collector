# Required Telegram credentials
TELEGRAM_BOT_TOKEN=replace_me
# Use the exact chat ID that is allowed to be collected
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Storage
SQLITE_PATH=/data/collector.db
MEDIA_DIR=/data/media

# Polling + service schedule
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_DOWNLOAD_IMAGES=true
SERVICE_DAILY_HOUR=3
SERVICE_DAILY_MINUTE=0
SERVICE_IDLE_SLEEP_SECONDS=2

# Optional hybrid mode backfill (recommended for long downtime recovery)
TELEGRAM_HYBRID_BACKFILL_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Optional explicit chat reference for Telethon (username, invite link, or numeric ID)
TELEGRAM_BACKFILL_CHAT_REF=
# Telethon session file path (persist this)
TELEGRAM_BACKFILL_SESSION_PATH=/data/telethon.session
# 0 means no per-run limit. Set >0 to cap backfill messages per daily run.
TELEGRAM_BACKFILL_LIMIT=0

# Optional KaraKeep sync
KARAKEEP_SYNC_ENABLED=false
KARAKEEP_URL=http://localhost:3000
KARAKEEP_API_KEY=replace_me
